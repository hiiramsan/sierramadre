---

---

<section
    id="collection-section"
    class="relative w-full min-h-screen bg-[#111a10] overflow-hidden flex flex-col"
>
    <!-- Watermark background text -->
    <span
        aria-hidden="true"
        class="pointer-events-none select-none absolute inset-0 flex items-center justify-center
               font-display italic text-[22vw] text-white/[0.04] leading-none whitespace-nowrap z-0"
    >
        artesanal
    </span>

    <!-- Header -->
    <div class="relative z-10 px-10 md:px-16 pt-20 pb-10">
        <p class="text-amber-400 tracking-[0.3em] text-sm uppercase font-serif-elegant mb-1">
            EXPLORA
        </p>
        <h2 class="font-display italic text-5xl md:text-6xl text-white leading-none">
            Nuestra Colección
        </h2>
    </div>

    <!-- Bottles row -->
    <div id="collection-grid" class="relative z-10 grid grid-cols-2 md:grid-cols-4 gap-0 px-6 md:px-10 flex-1 items-center content-center">

            <!-- Bottle 1 -->
            <div class="collection-bottle flex flex-col items-center py-6" data-delay="0">
                <img
                    src="/images/bacanora.png"
                    alt="Bacanora Blanco"
                    class="bottle-img w-[70%] md:w-[75%] max-w-[260px] object-contain drop-shadow-2xl"
                />
                <div class="w-full px-4 pt-5 text-center">
                    <h3 class="font-display italic text-2xl md:text-3xl text-white leading-tight">
                        Bacanora<br/>Blanco
                    </h3>
                </div>
            </div>

            <!-- Bottle 2 -->
            <div class="collection-bottle flex flex-col items-center py-6" data-delay="120">
                <img
                    src="/images/bacanora.png"
                    alt="Bacanora Reposado"
                    class="bottle-img w-[70%] md:w-[75%] max-w-[260px] object-contain drop-shadow-2xl"
                />
                <div class="w-full px-4 pt-5 text-center">
                    <h3 class="font-display italic text-2xl md:text-3xl text-white leading-tight">
                        Bacanora<br/>Reposado
                    </h3>
                </div>
            </div>

            <!-- Bottle 3 -->
            <div class="collection-bottle flex flex-col items-center py-6" data-delay="240">
                <img
                    src="/images/bacanora.png"
                    alt="Bacanora Añejo"
                    class="bottle-img w-[70%] md:w-[75%] max-w-[260px] object-contain drop-shadow-2xl"
                />
                <div class="w-full px-4 pt-5 text-center">
                    <h3 class="font-display italic text-2xl md:text-3xl text-white leading-tight">
                        Bacanora<br/>Añejo
                    </h3>
                </div>
            </div>

            <!-- Bottle 4 -->
            <div class="collection-bottle flex flex-col items-center py-6" data-delay="360">
                <img
                    src="/images/bacanora.png"
                    alt="Bacanora Extra Añejo"
                    class="bottle-img w-[70%] md:w-[75%] max-w-[260px] object-contain drop-shadow-2xl"
                />
                <div class="w-full px-4 pt-5 text-center">
                    <h3 class="font-display italic text-2xl md:text-3xl text-white leading-tight">
                        Bacanora<br/>Extra Añejo
                    </h3>
                </div>
            </div>

        </div>

</section>

<style>
    .bottle-img {
        transition: transform 0.4s ease;
    }
    .collection-bottle:hover .bottle-img {
        transform: scale(1.08) rotate(4deg);
    }
</style>
